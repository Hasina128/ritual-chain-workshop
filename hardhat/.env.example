# Copy to .env and fill in, OR use: pnpm exec hardhat keystore set DEPLOYER_PRIVATE_KEY
#
# Wallet roles (generate fresh keys per submission — do not reuse):
#   CREATOR / DEPLOYER — bounty owner, deploys contract, funds RitualWallet, judgeAll, finalizeWinner
#   USER1            — participant A (commit + reveal)
#   USER2            — participant B (commit + reveal)
#
# Example addresses from a fresh keygen (replace with your own):
#   CREATOR  0xD7580e8A956c5C4047a942e9eC527D58C87C13fA
#   USER1    0xDa4403d9F702e5Ce7520bCbDF054A8f9EF4A5905
#   USER2    0xD9d58227BB51a41107BB2B5295D2123167ab112a

DEPLOYER_PRIVATE_KEY=
CREATOR_PRIVATE_KEY=
USER1_PRIVATE_KEY=
USER2_PRIVATE_KEY=

# Deployed AIJudge address (also set NEXT_PUBLIC_CONTRACT_ADDRESS in web/.env.local)
CONTRACT_ADDRESS=